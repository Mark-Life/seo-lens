{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "~": ["./src"],
      "~/*": ["./src/*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/seo-rules": ["../../packages/seo-rules/src/index.ts"],
      "@workspace/seo-rules/*": ["../../packages/seo-rules/src/*.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", ".wxt/wxt.d.ts"]
}

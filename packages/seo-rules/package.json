{
  "name": "@workspace/seo-rules",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@workspace/typescript-config": "workspace:*",
    "linkedom": "^0.18.12",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "fetch-schema": "curl -sSLf -o scripts/vendor/schemaorg-current-https.jsonld https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "update-schema": "bun scripts/generate-schema.ts",
    "update-schema:check": "bun scripts/generate-schema.ts --check"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  }
}
